{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@grx/ui/*": ["../../packages/ui/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.d.ts",
    "../../packages/ui/icons/MarketingIcon.tsx",
    "../../packages/ui/icons/MessageIcon.tsx",
    "../../packages/ui/icons/OpenFinanceIcon.tsx",
    "../../packages/ui/icons/SoftwareDevelopmentIcon.tsx",
    "../../packages/ui/icons/WarehousingIcon.tsx",
    "src/app/[locale]/pay/partner-program/HowItWorks.tsx",
    "../../packages/ui/icons/VerticalDividerIcon.tsx",
    "../../packages/ui/icons/FooterLogoIcon.tsx",
    "../../packages/ui/icons/HeaderLogo.tsx"
  ],
  "exclude": ["node_modules"]
}
