# Required for AWS Amplify + pnpm (https://github.com/aws-amplify/amplify-hosting/blob/main/FAQ.md#support-for-monorepo-framework)
node-linker=hoisted

shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
public-hoist-pattern[]=*tsx*
public-hoist-pattern[]=*@swc*
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-dom*